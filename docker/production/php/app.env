# Static runtime config for the production phpfpm container.
#
# Secrets and per-deployment values (APP_SECRET, DATABASE_URL, JWT_PASSPHRASE,
# CORS_ALLOW_ORIGIN, GOOGLE_*, …) are NOT here — they are injected via
# compose.prod.yaml `environment:` from the host .env.prod.local file.

APP_ENV=prod
APP_DEBUG=0

# Run pending Doctrine migrations on container start (see docker-entrypoint.sh).
RUN_MIGRATIONS=1

# Where uploaded files (avatars, covers) live — backed by a named volume in prod.
APP_SHARE_DIR=var/share

# JWT key paths (content is gitignored; the keys are mounted read-only at runtime).
JWT_SECRET_KEY=/var/www/app/config/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/app/config/jwt/public.pem

# No mail catcher in production — disable the transport unless a real DSN is
# provided via .env.prod.local.
MAILER_DSN=null://null
