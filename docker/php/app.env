# Static runtime config for the phpfpm container.
# Values that need to differ per machine go in .env (they are passed in via
# compose.yaml environment: using ${VAR} substitution, which wins over env_file).

APP_ENV=dev

# JWT key paths (content is gitignored; only the paths are static)
JWT_SECRET_KEY=/var/www/app/config/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/app/config/jwt/public.pem

# CORS — matches any localhost port (Vite dev server, etc.)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Mailer — internal Docker network address of Mailpit
MAILER_DSN=smtp://mailpit:1025

# Xdebug — override to "develop,debug" in compose.override.yaml to activate
XDEBUG_MODE=off
