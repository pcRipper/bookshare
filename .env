# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=51b49d2b994b041ee3691e0fbc9af03c93d0c3fb58fcb81bb21e459d62a49c1b
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="postgresql://app:changeme@127.0.0.1:5432/bookshare?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> google-oauth ###
GOOGLE_CLIENT_ID=none
GOOGLE_CLIENT_SECRET=none
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
###< google-oauth ###

###> docker ###
# Image versions — bump here to upgrade a service without editing compose.yaml
PHP_VERSION=8.4
POSTGRES_IMAGE=postgres:16-alpine
NGINX_VERSION=1.27
MERCURE_IMAGE=dunglas/mercure:v0.24
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
ALLOY_IMAGE=grafana/alloy:v1.5.0
GRAFANA_IMAGE=grafana/grafana:11.4.0

# Host ports (change if a port is already taken on your machine)
HTTP_PORT=80
HTTPS_PORT=443
POSTGRES_PORT=5432
GRAFANA_PORT=3000

# PHP runtime tuning (read by php.ini via env-var expansion)
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX=50M
PHP_POST_MAX=50M
PHP_MAX_EXEC=60

# Database credentials (override in .env.local for production)
POSTGRES_DB=bookshare
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
###< docker ###

###> symfony/mercure-bundle ###
# Shared HMAC secret: Symfony signs publisher + subscriber JWTs with it, and the
# hub (compose `mercure` service) verifies them with the same key. CHANGE IN PROD.
MERCURE_JWT_SECRET=
# Server-side publish endpoint — the hub's hostname on the internal docker network.
MERCURE_URL=http://mercure/.well-known/mercure
# Browser-facing path. Kept RELATIVE on purpose: the subscribe-cookie is then
# host-only and follows whatever domain serves it, so this needs no per-env
# override (an absolute host here would 500 the cookie endpoint on any other
# domain — see Authorization::getCookieDomain).
MERCURE_PUBLIC_URL=/.well-known/mercure
# CORS origin(s) the hub accepts. Only consulted for cross-origin subscribers;
# our SPA reaches the hub same-origin through nginx, so this is just a safety net.
# Consumed by compose, not Symfony.
MERCURE_CORS_ORIGINS='https://localhost http://localhost'
###< symfony/mercure-bundle ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###
