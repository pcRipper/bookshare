# Production secrets + per-deployment config for compose.prod.yaml.
# Copy to .env.prod.local on the droplet (gitignored) and fill in real values.
#   cp .env.prod.local.example .env.prod.local

# ── Registry / image coordinates ─────────────────────────────────────────────
REGISTRY=registry.example.com/your-namespace
IMAGE_TAG=latest

# ── Symfony ──────────────────────────────────────────────────────────────────
# Generate: php -r 'echo bin2hex(random_bytes(16)), "\n";'
APP_SECRET=
DEFAULT_URI=https://your-domain.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=bookshare
POSTGRES_USER=app
POSTGRES_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Passphrase used when the config/jwt keypair was generated on the droplet.
JWT_PASSPHRASE=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Tighten to the production frontend origin (regex, origin_regex is on).
CORS_ALLOW_ORIGIN=^https://your-domain\.com$

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ── TLS / ACME (Let's Encrypt) ───────────────────────────────────────────────
# Host dir mounted into nginx at /etc/nginx/certs (certbot --deploy-hook copies
# fullchain.pem + privkey.pem here). Host dir for the http-01 webroot challenge.
TLS_CERT_DIR=./docker/production/nginx/certs
ACME_WEBROOT=./var/certbot

# ── Migrations ───────────────────────────────────────────────────────────────
# 1 = apply pending migrations on phpfpm start; 0 = skip (run make prod-migrate).
RUN_MIGRATIONS=1
